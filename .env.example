# Copy to .env and fill in. The agents read these at startup.

# --- Vertex AI / GCP (required) ---
# Your Google Cloud project ID. If unset, it is resolved from Application
# Default Credentials (gcloud auth application-default login).
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Where Gemini requests are served. gemini-3-pro is only on the "global"
# endpoint (not regional endpoints like us-central1). This is separate from the
# Cloud Run deployment region.
GOOGLE_CLOUD_LOCATION=global

# Use Vertex AI (True) rather than the AI Studio API key path (False).
GOOGLE_GENAI_USE_VERTEXAI=True

# --- Cloud SQL session storage (used by the gateway on Cloud Run) ---
# Leave unset for local in-memory sessions. Set all of these to use Cloud SQL.
# INSTANCE_CONNECTION_NAME=project:region:instance
# DB_USER=postgres
# DB_NAME=postgres
# DB_PASS=your-db-password

# --- Optional observability ---
# GCS bucket for artifacts and prompt/response logs.
# LOGS_BUCKET_NAME=your-logs-bucket
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=NO_CONTENT

# Structured logging (structlog). Format auto-detects: JSON on Cloud Run (where
# K_SERVICE is set), colorized console locally. Override either:
# LOG_FORMAT=json        # force JSON (or: console)
# LOG_LEVEL=INFO         # DEBUG also unmutes noisy google/httpx/uvicorn loggers

# --- Web API origins / CORS for the gateway (Phase 5) ---
# Comma-separated origins allowed to call the API (the Next.js frontend). Drives
# both ADK's cross-origin gate and the CORS headers. WEB_ORIGINS takes
# precedence; ALLOW_ORIGINS is the fallback. Defaults to http://localhost:3000.
# WEB_ORIGINS=https://your-frontend.example.com
# ALLOW_ORIGINS=https://your-frontend.example.com

# --- Tailored resume storage (Phase 6/7) ---
# GCS bucket for tailored resumes + submission screenshots. Defaults to
# "<GOOGLE_CLOUD_PROJECT>-resumes" if unset.
# RESUME_BUCKET=your-project-resumes

# --- Company sweep (Phase 3.6) ---
# Serper.dev search API key. NOTE: a PAID plan is required — the free tier
# rejects site: / advanced-operator queries ("Query pattern not allowed").
# SERPER_API_KEY=
# Sweep backend: "serper" (paid, reliable) or "direct" (free Google scraping, fragile).
# DISCOVERY_BACKEND=serper

# --- Web API (Phase 5) ---
# Local-only auth bypass for the web endpoints. NEVER enable in production.
# AUTH_DEV_MODE=1
# AUTH_DEV_USER=me
# Allowed CORS origins for the Next.js frontend (comma-separated).
# WEB_ORIGINS=http://localhost:3000

# --- Web frontend dev tools (Phase: onboarding) ---
# Shows dev-only affordances in the web app — currently the onboarding
# "Use a sample resume" button, which runs a real extraction and overwrites the
# signed-in user's profile. On automatically under `next dev`; set to 1 at BUILD
# time to also expose them on a deployed dev instance. Leave unset in production.
# NEXT_PUBLIC_DEV_TOOLS=1
