# Copy to .env and fill in. The agents read these at startup.

# --- Vertex AI / GCP (required) ---
# Your Google Cloud project ID. If unset, it is resolved from Application
# Default Credentials (gcloud auth application-default login).
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Region where Gemini requests are served. us-central1 matches the Cloud Run
# deployment region. If gemini-3-pro requires the global endpoint, use: global
GOOGLE_CLOUD_LOCATION=us-central1

# Use Vertex AI (True) rather than the AI Studio API key path (False).
GOOGLE_GENAI_USE_VERTEXAI=True

# --- Cloud SQL session storage (used by the gateway on Cloud Run) ---
# Leave unset for local in-memory sessions. Set all of these to use Cloud SQL.
# INSTANCE_CONNECTION_NAME=project:region:instance
# DB_USER=postgres
# DB_NAME=postgres
# DB_PASS=your-db-password

# --- Optional observability ---
# GCS bucket for artifacts and prompt/response logs.
# LOGS_BUCKET_NAME=your-logs-bucket
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=NO_CONTENT

# --- Optional CORS for the gateway ---
# ALLOW_ORIGINS=https://your-frontend.example.com
